{
  "keywords": [
    "tools",
    "libs"
  ],
  "autoload": {
    "psr-4": {
      "braga\\tools\\": "src"
    },
    "files": [
      "src/tools/tools.php"
    ]
  },
  "name": "braga/tools",
  "type": "library",
  "description": "Many difrent tools lib",
  "license": "MIT",
  "require": {
    "braga/graylogger": "@stable",
    "braga/enginerule": "@stable",
    "lcobucci/jwt": "@stable",
    "lcobucci/clock": "@stable",
    "codercat/jwk-to-pem": "@stable",
    "netresearch/jsonmapper": "@stable",
    "guzzlehttp/guzzle": "@stable",
    "php": ">=8.3",
    "ext-json": "*",
    "ext-calendar": "*",
    "ext-mbstring": "*",
    "ext-iconv": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "@stable"
  },
  "minimum-stability": "stable"
}